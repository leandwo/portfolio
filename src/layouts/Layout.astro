---
import '../styles/tailwind.css'
interface Props { title?: string }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} — Leandro Solidum` : 'Leandro Solidum'}</title>
		<script is:inline>
			(function () {
				var t = localStorage.getItem('theme') || 'system';
				if (t === 'dark' || (t === 'system' && matchMedia('(prefers-color-scheme: dark)').matches)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
	</head>
	<body class="flex h-full bg-white flex-col dark:bg-zinc-900">
		<div aria-hidden="true" class="glow-top pointer-events-none fixed inset-x-0 top-0 -z-10 h-96"></div>
		<div class="relative w-full max-w-xl mx-auto p-4">
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
