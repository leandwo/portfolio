---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    name: "Koinonia Church",
    description: "Official website for Koinonia Church in Mount Vernon, WA.",
    tech: ["Astro", "Tailwind CSS", "Cloudflare Pages"],
    url: "https://ko.church",
    repo: "https://github.com/leandwo/ko-church",
  },
];

const tools = [
  {
    name: "Song Prep",
    description: "Paste a ChordPro file, pick your transforms, get clean lyrics ready for Proclaim or any worship display.",
    url: "https://song-prep.ko.church",
  },
];
---

<Layout>
  <Header />
  <main>
    <!-- Hero -->
    <section class="mt-16 mb-10 rounded-xl border dark:border-zinc-800 dark:bg-zinc-800/20 p-6">
      <h1 class="text-2xl font-bold dark:text-zinc-100 leading-tight">
        Let's build something.
      </h1>
      <p class="mt-2 dark:text-zinc-400 leading-relaxed">
        I create websites, apps, and automations mostly for churches and small businesses.
        I care about shipping things that actually work and are worth using.
      </p>
    </section>

    <!-- Projects -->
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest dark:text-zinc-500 mb-4">Projects</h2>
      {projects.length === 0 ? (
        <div class="rounded-lg border border-dashed dark:border-zinc-800 p-10 flex items-center justify-center">
          <p class="text-xs dark:text-zinc-700 tracking-wide uppercase">Coming soon</p>
        </div>
      ) : (
        <div class="flex flex-col gap-4">
          {projects.map((project) => (
            <div class="rounded-lg dark:bg-zinc-800/40 border dark:border-zinc-800 p-5 group">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-medium dark:text-zinc-100">{project.name}</p>
                  <p class="text-sm dark:text-zinc-400 mt-1 leading-relaxed">{project.description}</p>
                  <div class="flex items-center gap-3 mt-3 group/repo">
                    <div class="flex flex-wrap gap-1">
                      {project.tech.map((t) => (
                        <span class="text-xs px-2 py-0.5 rounded dark:bg-zinc-800/60 dark:text-zinc-500 border dark:border-zinc-700/40 transition-colors group-hover/repo:dark:text-zinc-400 group-hover/repo:dark:border-zinc-600/60">{t}</span>
                      ))}
                    </div>
                    {project.repo && (
                      <a href={project.repo} target="_blank" rel="noopener noreferrer" class="opacity-0 group-hover/repo:opacity-100 transition-opacity flex items-center gap-1 text-xs dark:text-zinc-500 dark:hover:text-zinc-300">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                        Source
                      </a>
                    )}
                  </div>
                </div>
                <div class="flex gap-3 shrink-0 pt-0.5">
                  {project.url && (
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-xs dark:text-sky-400 dark:hover:text-sky-300 transition-colors">Live ↗</a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
      <p class="mt-4 text-xs dark:text-zinc-600">Have a project in mind? <a href="mailto:hi@leandro.codes" class="underline underline-offset-2 dark:hover:text-zinc-400 transition-colors">Let's talk.</a></p>
    </section>

    <!-- Prototypes -->
    <section class="mb-12">
      <h2 class="text-xs font-semibold uppercase tracking-widest dark:text-zinc-500 mb-4">Tools</h2>
      {tools.length === 0 ? (
        <div class="rounded-lg border border-dashed dark:border-zinc-800 p-10 flex items-center justify-center">
          <p class="text-xs dark:text-zinc-700 tracking-wide uppercase">Coming soon</p>
        </div>
      ) : (
        <div class="divide-y dark:divide-zinc-800/60">
          {tools.map((tool) => (
            <div class="py-3 flex items-baseline justify-between gap-4">
              <div class="min-w-0">
                {tool.url ? (
                  <a href={tool.url} target="_blank" rel="noopener noreferrer" class="text-sm font-medium dark:text-zinc-100 dark:hover:text-sky-400 transition-colors">{tool.name}</a>
                ) : (
                  <span class="text-sm font-medium dark:text-zinc-100">{tool.name}</span>
                )}
                <span class="text-sm dark:text-zinc-500 ml-2">{tool.description}</span>
              </div>
              {tool.url && (
                <a href={tool.url} target="_blank" rel="noopener noreferrer" class="text-xs dark:text-sky-400 dark:hover:text-sky-300 transition-colors shrink-0">↗</a>
              )}
            </div>
          ))}
        </div>
      )}
    </section>

  </main>
  <Footer />
</Layout>
