---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const tools = [
  {
    name: "Song Prep",
    description: "Paste a ChordPro file, pick your transforms, get clean lyrics ready for Proclaim or any worship display.",
    url: "https://song-prep.ko.church",
  },
];
---

<Layout>
  <Header />
  <main>
    <!-- Hero -->
    <section class="mt-10 mb-14">
      <div class="flex items-center gap-2 mb-5">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        <span class="text-xs text-zinc-400 dark:text-zinc-500 tracking-wide">Available for projects</span>
      </div>
      <h1 class="text-4xl font-bold text-zinc-900 dark:text-zinc-50 leading-tight tracking-tight mb-4">
        Let's build something.
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed max-w-sm">
        I create websites, apps, and automations mostly for churches and small businesses.
        I care about shipping things that actually work and are worth using.
      </p>
    </section>

    <!-- Projects -->
    <section class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-4">Projects</h2>
      {projects.length === 0 ? (
        <div class="rounded-xl border border-dashed border-zinc-200 dark:border-zinc-800 p-10 flex items-center justify-center">
          <p class="text-xs text-zinc-300 dark:text-zinc-700 tracking-wide uppercase">Coming soon</p>
        </div>
      ) : (
        <div class="flex flex-col gap-3">
          {projects.map((project) => (
            <div class="relative rounded-xl bg-white border border-zinc-200 dark:bg-zinc-800/40 dark:border-zinc-800 p-5 group transition-all duration-200 hover:border-zinc-300 dark:hover:border-zinc-700/80 overflow-hidden cursor-pointer">
              <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sky-400/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              {/* Stretched link covers the whole card */}
              <a href={`/projects/${project.slug}`} class="absolute inset-0 rounded-xl" aria-label={`View ${project.data.name} project`}></a>
              <div class="relative flex items-start justify-between gap-4">
                <div>
                  <p class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-sky-600 dark:group-hover:text-sky-400 transition-colors">{project.data.name}</p>
                  <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1 leading-relaxed">{project.data.description}</p>
                  <div class="flex flex-wrap gap-1 mt-3">
                    {project.data.tech.map((t) => (
                      <span class="text-xs px-2 py-0.5 rounded-md bg-zinc-100 text-zinc-500 border border-zinc-200 dark:bg-zinc-800/60 dark:text-zinc-500 dark:border-zinc-700/40">{t}</span>
                    ))}
                  </div>
                </div>
                <div class="relative z-10 shrink-0 flex flex-col items-end gap-2 pt-0.5">
                  {project.data.url ? (
                    <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-xs font-medium border border-sky-200 bg-sky-50 text-sky-600 hover:bg-sky-100 dark:border-sky-900/60 dark:bg-sky-950/20 dark:text-sky-400 dark:hover:bg-sky-950/40 px-2.5 py-1 rounded-full transition-colors">
                      Live ↗
                    </a>
                  ) : (
                    <span class={`text-xs px-2 py-0.5 rounded-full border font-medium ${
                      project.data.status === 'wip'
                        ? 'bg-amber-50 text-amber-600 border-amber-200 dark:bg-amber-950/30 dark:text-amber-400 dark:border-amber-900/50'
                        : 'bg-zinc-100 text-zinc-500 border-zinc-200 dark:bg-zinc-800 dark:text-zinc-400 dark:border-zinc-700'
                    }`}>
                      {project.data.status === 'wip' ? 'In progress' : 'Private'}
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
      <div class="mt-6 rounded-xl border border-dashed border-zinc-200 dark:border-zinc-800 p-4 text-center">
        <p class="text-sm text-zinc-400 dark:text-zinc-500">
          Have a project in mind?{" "}
          <a href="mailto:hi@leandro.codes" class="font-medium text-zinc-700 dark:text-zinc-300 underline underline-offset-2 hover:text-sky-500 dark:hover:text-sky-400 transition-colors">
            Let's talk.
          </a>
        </p>
      </div>
    </section>

    <!-- Tools -->
    <section class="mb-12">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-4">Tools</h2>
      {tools.length === 0 ? (
        <div class="rounded-xl border border-dashed border-zinc-200 dark:border-zinc-800 p-10 flex items-center justify-center">
          <p class="text-xs text-zinc-300 dark:text-zinc-700 tracking-wide uppercase">Coming soon</p>
        </div>
      ) : (
        <div class="divide-y divide-zinc-100 dark:divide-zinc-800/60">
          {tools.map((tool) => (
            <div class="py-3.5 flex items-center justify-between gap-4">
              <div class="min-w-0">
                {tool.url ? (
                  <a href={tool.url} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-zinc-800 hover:text-sky-500 dark:text-zinc-100 dark:hover:text-sky-400 transition-colors">{tool.name}</a>
                ) : (
                  <span class="text-sm font-semibold text-zinc-800 dark:text-zinc-100">{tool.name}</span>
                )}
                <span class="text-sm text-zinc-400 dark:text-zinc-500 ml-2">{tool.description}</span>
              </div>
              {tool.url && (
                <a href={tool.url} target="_blank" rel="noopener noreferrer" class="shrink-0 flex items-center gap-1 text-xs font-medium border border-sky-200 bg-sky-50 text-sky-600 hover:bg-sky-100 dark:border-sky-900/60 dark:bg-sky-950/20 dark:text-sky-400 dark:hover:bg-sky-950/40 px-2.5 py-1 rounded-full transition-colors">
                  Open ↗
                </a>
              )}
            </div>
          ))}
        </div>
      )}
    </section>

  </main>
  <Footer />
</Layout>
